{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "component": "talenti-platform",
      "release-type": "simple",
      "version-file": "VERSION",
      "changelog-path": "CHANGELOG.md",
      "include-component-in-tag": false,
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "refactor",
          "section": "Refactors"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "ci",
          "section": "CI"
        },
        {
          "type": "chore",
          "section": "Chores"
        }
      ]
    }
  }
}
